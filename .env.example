# ── Unattended install (used by scripts/proxmox.sh and CI) ────────────────────
# Set VOTEHOST_UNATTENDED=1 to skip all prompts in scripts/install.sh.
# VOTEHOST_TUNNEL_MODE=cloudflare   # cloudflare | tailscale | lan
# VOTEHOST_PUBLIC_URL=https://vote.example.com
# VOTEHOST_CLOUDFLARE_TUNNEL_TOKEN= # required for cloudflare mode
# VOTEHOST_TS_AUTHKEY=              # required for tailscale mode
# VOTEHOST_TS_HOSTNAME=votehost     # tailscale hostname (default: votehost)
# VOTEHOST_ADMIN_EMAIL=             # optional — skips admin bootstrap if unset
# VOTEHOST_ADMIN_PASSWORD=          # required when VOTEHOST_ADMIN_EMAIL is set

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=votehost
POSTGRES_PASSWORD=changeme          # replace — run: openssl rand -hex 16
POSTGRES_DB=votehost
DATABASE_URL=postgresql://votehost:changeme@db:5432/votehost

# ── Auth / Security ───────────────────────────────────────────────────────────
# NEXTAUTH_SECRET also derives the TOTP encryption key and 2FA challenge token secret.
NEXTAUTH_SECRET=                    # required — run: openssl rand -hex 32
NEXTAUTH_URL=https://vote.example.com  # comma-separated for multi-host: https://a.example.com,https://b.example.com

# ── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET=                        # required — run: openssl rand -hex 32

# ── First-run bootstrap ────────────────────────────────────────────────────────
SETUP_TOKEN=                        # required — run: openssl rand -hex 32 (delete after first admin is created)

# ── Email (configure via admin Settings panel after first login, or set here) ─
# RESEND_API_KEY=re_...             # optional — or configure SMTP in admin Settings

# ── Display timezone ──────────────────────────────────────────────────────────
# IANA timezone used to render times in outbound emails (e.g. America/New_York).
# Defaults to the server's system timezone (UTC in Docker) when unset.
# DISPLAY_TIME_ZONE=America/New_York

# ── Tunnel (only needed with --profile cloudflare or --profile tailscale) ─────
CLOUDFLARE_TUNNEL_TOKEN=            # dash.cloudflare.com → Networks → Tunnels
TS_AUTHKEY=                         # login.tailscale.com/admin/settings/keys
TS_HOSTNAME=votehost
# TS_EXTRA_ARGS=--advertise-tags=tag:votehost  # isolated mode (recommended default); set to empty for non-isolated
