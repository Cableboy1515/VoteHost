generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ElectionStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RANKED_CHOICE
  WRITE_IN
}

model Election {
  id          String         @id @default(cuid())
  title       String
  description String?
  status      ElectionStatus @default(DRAFT)
  archived    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  startsAt    DateTime?
  endsAt      DateTime?

  emailSubject     String?
  emailMessage     String?
  emailLogoUrl     String?
  emailLogoDeleteUrl String?
  emailFooter      String?

  firstReminderDays  Int?
  resultsEmailSentAt DateTime?
  imagesPurgedAt     DateTime?

  firstVoteAt     DateTime?
  ballotResetAt   DateTime?
  ballotResetById String?

  closedAt     DateTime?
  closedById   String?
  reopenedAt   DateTime?
  reopenedById String?

  endsSoonNoticeSentAt           DateTime?
  completionEmailSentAt          DateTime?
  startReminderSentAt            DateTime?
  startedEmailSentAt             DateTime?
  fullTurnoutNoticeSentAt        DateTime?

  activatedAt                    DateTime?
  activatedById                  String?
  autoActivate                   Boolean   @default(true)
  autoActivateFailedNoticeSentAt DateTime?
  autoSendResults                Boolean   @default(false)

  heroColor              String?
  dashboardDismissedAt   DateTime?

  tallyHash      String?
  tallyHashSetAt DateTime?

  questions    Question[]
  voters       Voter[]
  votes        Vote[]
  receipts     BallotReceipt[]
  activityLogs ActivityLog[]
}

model Question {
  id         String       @id @default(cuid())
  electionId String
  text       String
  description   String?
  type       QuestionType
  order         Int
  required         Boolean      @default(true)
  maxSelections    Int?
  randomizeOptions Boolean      @default(false)
  showOptionAvatars Boolean     @default(true)

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  options  Option[]
  votes    Vote[]

  @@index([electionId, order])
}

model Option {
  id         String @id @default(cuid())
  questionId String
  text       String
  order      Int
  bio           String?
  photoUrl      String?
  photoDeleteUrl String?
  website       String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  votes    Vote[]

  @@index([questionId, order])
}

model Voter {
  id                   String    @id @default(cuid())
  electionId           String
  name                 String
  email                String
  hasVoted             Boolean   @default(false)
  invitedAt            DateTime?
  votedAt              DateTime?
  firstReminderSentAt  DateTime?
  secondReminderSentAt DateTime?
  recoveryRequestedAt  DateTime?
  lastSendStatus       String?
  lastSendErrorCode    String?
  lastSendErrorMessage String?
  lastSendAttemptAt    DateTime?
  lastSendProvider     String?

  election     Election            @relation(fields: [electionId], references: [id], onDelete: Cascade)
  tokenHistory VoterTokenHistory[]

  @@unique([electionId, email])
  @@index([electionId, lastSendStatus])
}

model VoterTokenHistory {
  id        String   @id @default(cuid())
  voterId   String
  voter     Voter    @relation(fields: [voterId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())

  @@index([voterId])
}

// Vote has no voterId — anonymity by design.
// WHO voted is on Voter.hasVoted; WHAT was voted is here with no voter linkage.
model Vote {
  id          String   @id @default(cuid())
  electionId  String
  questionId  String
  optionId    String?
  rank        Int?
  writeInText String?
  ballotId    String?
  createdAt   DateTime @default(now())

  election Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   Option?   @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([electionId, questionId])
  @@index([ballotId])
}

model BallotReceipt {
  id          String   @id @default(cuid())
  electionId  String
  receiptCode String   @unique
  ballotHash  String
  createdAt   DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId])
}

enum AdminRole {
  ADMIN
  ORGANIZER
  VIEWER
  SYSTEM
}

model AdminUser {
  id                       String    @id @default(cuid())
  email                    String    @unique
  passwordHash             String?
  role                     AdminRole @default(ORGANIZER)
  tokenVersion             Int       @default(0)
  passwordChangedAt        DateTime?
  createdAt                DateTime  @default(now())

  invitationTokenHash      String?   @unique
  invitationExpiresAt      DateTime?
  invitedAt                DateTime?
  invitedById              String?
  passwordResetRequestedAt DateTime?
  passwordResetTokenHash   String?   @unique
  passwordResetExpiresAt   DateTime?

  // TOTP 2FA — optional for all roles, recommended for ADMIN and ORGANIZER
  totpSecretEnc              String?   // AES-256-GCM encrypted TOTP secret
  totpEnabledAt              DateTime?
  recoveryCodeHashes         String[]  @default([]) // bcrypt hashes of one-time recovery codes
  twoFactorPromptDismissedAt DateTime? // set when user skips the post-login 2FA recommendation
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  actorId     String?
  actorEmail  String
  actorRole   AdminRole

  electionId  String?
  election    Election? @relation(fields: [electionId], references: [id], onDelete: Cascade)

  action      String
  targetType  String
  targetId    String?
  targetLabel String?
  metadata    Json?

  @@index([electionId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
