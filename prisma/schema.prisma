generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ElectionStatus {
  DRAFT
  ACTIVE
  PENDING_REVIEW // Voting closed; write-in merges in progress before tally is sealed
  COMPLETED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RANKED_CHOICE
  COMMENT // Free-text / feedback; collected for organizer review, not tallied
}

enum QuorumType {
  NONE
  PERCENT
  COUNT
}

model Election {
  id          String         @id @default(cuid())
  title       String
  description String?
  status      ElectionStatus @default(DRAFT)
  archived    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  startsAt    DateTime?
  endsAt      DateTime?

  emailSubject     String?
  emailMessage     String?
  emailLogoUrl     String?
  emailLogoDeleteUrl String?
  emailFooter      String?

  firstReminderDays  Int?
  resultsEmailSentAt DateTime?
  imagesPurgedAt     DateTime?

  firstVoteAt     DateTime?
  ballotResetAt   DateTime?
  ballotResetById String?

  closedAt     DateTime?
  closedById   String?
  reopenedAt   DateTime?
  reopenedById String?

  endsSoonNoticeSentAt           DateTime?
  completionEmailSentAt          DateTime?
  startReminderSentAt            DateTime?
  startedEmailSentAt             DateTime?
  fullTurnoutNoticeSentAt        DateTime?

  activatedAt                    DateTime?
  activatedById                  String?
  autoActivate                   Boolean   @default(true)
  autoActivateFailedNoticeSentAt DateTime?
  autoSendResults                Boolean   @default(false)

  heroColor              String?
  dashboardDismissedAt   DateTime?

  weightingEnabled Boolean    @default(false)

  quorumType     QuorumType @default(NONE)
  quorumValue    Int?

  tallyHash      String?
  tallyHashSetAt DateTime?

  // Write-in review / finalization
  finalizedAt               DateTime?
  finalizedById             String?
  normalizationManifestHash String?   // sha256 of sorted WriteInMerge manifest, set at Finalize

  questions     Question[]
  voters        Voter[]
  votes         Vote[]
  receipts      BallotReceipt[]
  activityLogs  ActivityLog[]
  writeInMerges WriteInMerge[]
}

model Question {
  id         String       @id @default(cuid())
  electionId String
  text       String
  description   String?
  type       QuestionType
  order         Int
  required         Boolean      @default(true)
  maxSelections    Int?
  seats            Int          @default(1)
  randomizeOptions Boolean      @default(false)
  showOptionAvatars Boolean     @default(true)

  // Write-in on choice questions — allow voters to type a candidate name
  // instead of (or in addition to) picking a pre-listed option.
  // Only meaningful on SINGLE_CHOICE, MULTIPLE_CHOICE, RANKED_CHOICE.
  // When true, elections with this question park in PENDING_REVIEW at close
  // so an admin can merge spelling variants before the tally is sealed.
  allowWriteIn Boolean @default(false)

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  options  Option[]
  votes    Vote[]
  writeInMerges WriteInMerge[]

  @@index([electionId, order])
}

model Option {
  id         String @id @default(cuid())
  questionId String
  text       String
  order      Int
  bio           String?
  photoUrl      String?
  photoDeleteUrl String?
  website       String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  votes    Vote[]

  @@index([questionId, order])
}

model Voter {
  id                   String    @id @default(cuid())
  electionId           String
  name                 String
  email                String
  weight               Int       @default(1)
  hasVoted             Boolean   @default(false)
  invitedAt            DateTime?
  votedAt              DateTime?
  firstReminderSentAt  DateTime?
  secondReminderSentAt DateTime?
  recoveryRequestedAt  DateTime?
  lastSendStatus       String?
  lastSendErrorCode    String?
  lastSendErrorMessage String?
  lastSendAttemptAt    DateTime?
  lastSendProvider     String?

  election     Election            @relation(fields: [electionId], references: [id], onDelete: Cascade)
  tokenHistory VoterTokenHistory[]

  @@unique([electionId, email])
  @@index([electionId, lastSendStatus])
}

model VoterTokenHistory {
  id        String   @id @default(cuid())
  voterId   String
  voter     Voter    @relation(fields: [voterId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())

  @@index([voterId])
}

// Vote has no voterId — anonymity by design.
// WHO voted is on Voter.hasVoted; WHAT was voted is here with no voter linkage.
model Vote {
  id          String   @id @default(cuid())
  electionId  String
  questionId  String
  optionId    String?
  rank        Int?
  writeInText String?
  ballotId    String?
  weight      Int      @default(1)
  createdAt   DateTime @default(now())

  election Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   Option?   @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([electionId, questionId])
  @@index([ballotId])
}

model BallotReceipt {
  id          String   @id @default(cuid())
  electionId  String
  receiptCode String   @unique
  ballotHash  String
  createdAt   DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId])
}

// Non-destructive overlay: maps raw write-in text to a canonical candidate name.
// Raw Vote.writeInText is NEVER mutated — the tally hash is computed over raw
// votes only. This manifest is published alongside the audit export so any
// observer can reproduce the merged tally deterministically.
model WriteInMerge {
  id             String   @id @default(cuid())
  electionId     String
  questionId     String
  rawText        String   // exact raw Vote.writeInText being merged
  canonicalLabel String   // the merged candidate name shown in results
  mergedById     String
  mergedByEmail  String
  createdAt      DateTime @default(now())

  election Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([electionId, questionId, rawText]) // one mapping per raw string per question
  @@index([electionId, questionId])
}

enum AdminRole {
  ADMIN
  ORGANIZER
  VIEWER
  SYSTEM
}

model AdminUser {
  id                       String    @id @default(cuid())
  email                    String    @unique
  passwordHash             String?
  role                     AdminRole @default(ORGANIZER)
  tokenVersion             Int       @default(0)
  passwordChangedAt        DateTime?
  createdAt                DateTime  @default(now())

  invitationTokenHash      String?   @unique
  invitationExpiresAt      DateTime?
  invitedAt                DateTime?
  invitedById              String?
  passwordResetRequestedAt DateTime?
  passwordResetTokenHash   String?   @unique
  passwordResetExpiresAt   DateTime?

  // TOTP 2FA — optional for all roles, recommended for ADMIN and ORGANIZER
  totpSecretEnc              String?   // AES-256-GCM encrypted TOTP secret
  totpEnabledAt              DateTime?
  recoveryCodeHashes         String[]  @default([]) // bcrypt hashes of one-time recovery codes
  twoFactorPromptDismissedAt DateTime? // set when user skips the post-login 2FA recommendation
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  actorId     String?
  actorEmail  String
  actorRole   AdminRole

  electionId  String?
  election    Election? @relation(fields: [electionId], references: [id], onDelete: Cascade)

  action      String
  targetType  String
  targetId    String?
  targetLabel String?
  metadata    Json?

  @@index([electionId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
